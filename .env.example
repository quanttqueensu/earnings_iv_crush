# Copy this file to .env and fill in your values.
# .env is git-ignored: never commit real keys.
#
# Several sources work with no key at all (FRED VIX via the public CSV
# endpoint, yfinance equities and option chains). The keys below unlock the
# higher-quality or rate-limited providers.

SEC_USER_AGENT=      # required for SEC EDGAR, format: "Name email@example.com"
FINNHUB_API_KEY=     # earnings calendar
TIINGO_API_KEY=      # equity OHLCV (yfinance is the keyless fallback)
FRED_API_KEY=        # VIX series (the public CSV endpoint also works keyless)
ALPACA_KEY=          # historical option surfaces (Alpaca free, since ~Feb 2024)
ALPACA_SECRET=       # pairs with ALPACA_KEY
DATABENTO_API_KEY=   # OPRA historical options (daily bars/definitions, back to 2013)

# IBKR live paper harness (live/). No key: TWS/IB Gateway must be running with the
# API enabled. These only override the safe defaults (auto-detect paper ports,
# delayed data, read-only) when set; leave blank to use them.
IBKR_HOST=           # API host (default 127.0.0.1)
IBKR_CLIENT_ID=      # API client id (default 17)
IBKR_ACCOUNT=        # paper account, e.g. DU1234567 (default: the sole managed one)
IBKR_MKT_DATA_TYPE=  # 1 live, 2 frozen, 3 delayed (default), 4 delayed-frozen
