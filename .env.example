# Copy this file to .env and fill in your values.
# .env is git-ignored: never commit real keys.
#
# Several sources work with no key at all (FRED VIX via the public CSV
# endpoint, yfinance equities and option chains). The keys below unlock the
# higher-quality or rate-limited providers.

SEC_USER_AGENT=      # required for SEC EDGAR, format: "Name email@example.com"
FINNHUB_API_KEY=     # earnings calendar
TIINGO_API_KEY=      # equity OHLCV (yfinance is the keyless fallback)
FRED_API_KEY=        # VIX series (the public CSV endpoint also works keyless)
ALPACA_KEY=          # historical option surfaces since Feb 2024 (pending)
ALPACA_SECRET=       # pairs with ALPACA_KEY
